{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "juniorfontenele/laravel-exceptions",
    "description": "A custom handler for Laravel Exceptions",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "JuniorFontenele\\LaravelExceptions\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Junior Fontenele",
            "email": "git@juniorfontenele.com.br"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/support": "^12"
    },
    "extra": {
        "laravel": {
            "providers": [
                "JuniorFontenele\\LaravelExceptions\\LaravelExceptionsServiceProvider"
            ],
            "aliases": {
                "LaravelExceptions": "JuniorFontenele\\LaravelExceptions\\Facades\\LaravelExceptions"
            }
        }
    },
    "require-dev": {
        "orchestra/testbench": "^10.8",
        "pestphp/pest": "^4.3",
        "pestphp/pest-plugin-faker": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/",
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "test": "vendor/bin/pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
